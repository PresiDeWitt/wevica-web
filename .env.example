# Google Analytics 4 — measurement ID (public, safe to expose in client)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Resend — for newsletter subscriber notifications
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXX

# Email address to receive subscriber notifications (default: hola@wevica.com)
NOTIFY_EMAIL=hola@wevica.com

# Crisp chat widget ID
# Get it at: https://app.crisp.chat → Settings → Website Settings
CRISP_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
